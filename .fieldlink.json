        "consumed_by": ["experiments/sims/geometric_sensing_sim.py", "src/geometric_monitoring_engine.py"]
      },
      {
        "name": "soms",
        "repo": "https://github.com/JinnZ2/Sovereign-Octahedral-Mandala-Substrate-SOMS-",
